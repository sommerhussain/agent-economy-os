# Universal Agent Economy OS - Environment Configuration

# API Security
# The master API key required to access protected endpoints (like /proxy/execute).
# Clients must send this via the 'Authorization: Bearer <key>' or 'X-API-Key: <key>' header.
# For production (e.g. Railway), generate a strong random string (e.g. `openssl rand -hex 32`).
API_KEY=sk_test_1234567890abcdef

# Supabase Configuration (Identity & Credential Vault)
# Replace with your actual Supabase project URL and Key
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-anon-or-service-role-key

# CORS Configuration
# Pydantic v2 parses lists from JSON strings. Use '["*"]' to allow all, or '["http://localhost:3000"]' for specific origins.
# For production, consider restricting this to your specific frontend domains.
ALLOWED_ORIGINS=["*"]

# Payment Gateway (Day 22)
# Set to simulate real Stripe integration
STRIPE_API_KEY=""
# Set to true to simulate Lightning network micropayments
LIGHTNING_ENABLED=false

# Billing Configuration (Day 23)
# The flat rate applied per API call for usage-based billing
BILLING_RATE_PER_CALL=0.01

# Webhook Security (Day 24)
# Secret used to verify HMAC signatures on incoming webhooks
# For production (e.g. Railway), generate a strong random string.
WEBHOOK_SECRET=whsec_test_secret

# Rate Limiting (Day 26)
# Maximum number of requests an agent can make within the window
RATE_LIMIT_MAX_REQUESTS=10
# Time window in seconds for the rate limit
RATE_LIMIT_WINDOW_SECONDS=60

# Analytics & Dashboard (Day 37)
# Time window in seconds to consider an agent "active"
ANALYTICS_ACTIVE_WINDOW_SECONDS=86400
# Maximum number of recent events to keep in memory
ANALYTICS_MAX_RECENT_EVENTS=50
# Maximum number of recent invoices to display on the dashboard
DASHBOARD_RECENT_INVOICES_LIMIT=5
